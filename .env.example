# Orchestrator
WHATIF_ENV=local
ORCHESTRATOR_PORT=8080
# Upstash Redis REST credentials.
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
WHATIF_VERTEX_LOCATION=global
FIRESTORE_DATABASE="(default)"
WHATIF_PUBSUB_TOPIC=whatif-asset-jobs
WHATIF_VERTEX_MODEL=gemini-3.1-flash-lite-preview
WHATIF_INTERLEAVED_MODEL=gemini-3.1-flash-image-preview
WHATIF_INTERLEAVED_FALLBACK_MODEL=gemini-2.5-flash-image
WHATIF_AGENT_MAX_ATTEMPTS=3
WHATIF_AGENT_RETRY_BASE_DELAY_SECONDS=0.8
WHATIF_ORCHESTRATOR_CALLBACK_URL=http://localhost:8080/api/v1/assets/jobs/callback
GOOGLE_GENAI_USE_VERTEXAI=true
WHATIF_LIVE_APP_NAME=whatif-live
WHATIF_LIVE_MODEL=gemini-live-2.5-flash-native-audio
WHATIF_LIVE_LOCATION=us-central1
WHATIF_LIVE_VOICE=Aoede
WHATIF_INPUT_AUDIO_MIME=audio/pcm;rate=16000
WHATIF_ENABLE_AFFECTIVE_DIALOG=true
WHATIF_ENABLE_PROACTIVE_AUDIO=false
WHATIF_RUN_GCP_INFRA_TESTS=false
WHATIF_RUN_VERTEX_TESTS=false
WHATIF_LOCAL_STUBS=false
WHATIF_LOG_LEVEL=INFO
WHATIF_LOG_FILE=logs/orchestrator.log

# Workers
WHATIF_ASSET_BUCKET=your-asset-bucket
WHATIF_IMAGE_MODEL=imagen-3.0-generate-002
WHATIF_VIDEO_MODEL=veo-2.0-generate-001

# Frontend
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8080
